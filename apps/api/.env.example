PORT=3001
NODE_ENV=development

# PostgreSQL (Supabase or local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/startupsaarthi

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Clerk (get from clerk.com dashboard)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# CORS
FRONTEND_URL=http://localhost:3000

# Razorpay (get from razorpay.com dashboard)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Anthropic Claude (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Admin (comma-separated static tokens for Bull Board at /admin/queues)
ADMIN_TOKENS=your_secure_admin_token_here
