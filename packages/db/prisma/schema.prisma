generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  insights    Json?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}
