# ─────────────────────────────────────────────────────────────
# StartupSaarthi AI — Complete Environment Configuration
# Copy to .env (never commit the real .env to source control)
# ─────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://startupsaarthi.in
CORS_ORIGINS=https://startupsaarthi.in,https://www.startupsaarthi.in

# ── Database (PostgreSQL) ─────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://ssadmin:password@rds-endpoint:5432/startupsaarthi
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Cache (Redis) ─────────────────────────────────────────────
REDIS_HOST=elasticache-endpoint
REDIS_PORT=6379
REDIS_TTL_REPORT=86400      # 24 hours in seconds
REDIS_TTL_USER=3600         # 1 hour in seconds
REDIS_TTL_IDEA_DEDUP=604800 # 7 days in seconds

# ── Auth (Clerk) ──────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx   # From Clerk webhook dashboard

# ── AI (Anthropic) ────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=3072
ANTHROPIC_TIMEOUT_MS=120000   # 2 minute timeout for multi-agent

# ── Payments (Razorpay) ───────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx   # From Razorpay webhook dashboard

# Pricing (in paise — INR × 100)
RAZORPAY_PRO_PRICE_PAISE=49900      # ₹499/month
RAZORPAY_PREMIUM_PRICE_PAISE=149900  # ₹1499/month

# ── Storage (AWS S3) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=ap-south-1
S3_BUCKET_NAME=startupsaarthi-reports-production
S3_PRESIGNED_URL_EXPIRES=3600   # Pre-signed URL TTL in seconds

# ── Monitoring ────────────────────────────────────────────────
PROMETHEUS_PORT=9090
LOKI_URL=http://loki:3100
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# ── Admin ─────────────────────────────────────────────────────
ADMIN_TOKENS=your_secure_admin_token_here   # Comma-separated for Bull Board

# ── BullMQ Queue ─────────────────────────────────────────────
BULL_BOARD_ENABLED=true
