# ─────────────────────────────────────────────────────────────
# startupIQ — Complete Environment Configuration
# Copy to .env (never commit the real .env to source control)
# ─────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://startupiq.in
CORS_ORIGINS=https://startupiq.in,https://www.startupiq.in

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Cache (Redis) ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL_REPORT=86400      # 24 hours in seconds
REDIS_TTL_USER=3600         # 1 hour in seconds
REDIS_TTL_IDEA_DEDUP=604800 # 7 days in seconds

# ── AI APIs ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

GROQ_API_KEY=your_groq_api_key
GROQ_DEEPSEEK_MODEL=deepseek-r1-distill-qwen-32b
GROQ_QWEN_MODEL=qwen-qwq-32b

TAVILY_API_KEY=your_tavily_api_key

# Optional Anthropic (legacy)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=3072
ANTHROPIC_TIMEOUT_MS=120000

# ── Payments (Razorpay) ───────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Pricing (in paise — INR × 100)
RAZORPAY_PRO_PRICE_PAISE=49900
RAZORPAY_PREMIUM_PRICE_PAISE=149900


# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Email & SMS ───────────────────────────────────────────────
ENABLE_SMS=false
FAST2SMS_API_KEY=your_fast2sms_api_key
EMAIL_HOST=smtp-brevo.com
EMAIL_PORT=587
EMAIL_USER=your_email_user
EMAIL_PASS=your_email_password
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=+919000000000

# ── Security & Monitoring ─────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
ADMIN_TOKENS=your_secure_admin_token_here
BULL_BOARD_ENABLED=true
PROMETHEUS_PORT=9090
LOKI_URL=http://loki:3100
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

